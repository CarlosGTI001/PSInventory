@model PSData.Modelos.Region

@{
    ViewData["Title"] = "Editar Región";
}

<!-- Breadcrumb -->
<div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; color: var(--md-sys-color-on-surface-variant); font-size: 14px;">
    <md-icon style="font-size: 18px;">home</md-icon>
    <span>Administración</span>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <a href="@Url.Action("Index")" style="color: var(--md-sys-color-on-surface-variant); text-decoration: none;">Regiones</a>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <span style="color: var(--md-sys-color-primary);">Editar: @Model.Nombre</span>
</div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="md-typescale-display-small" style="margin: 0 0 8px 0;">Editar Región</h1>
        <p class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface-variant); margin: 0;">
            Modifica los datos de la región <strong>@Model.Nombre</strong>
        </p>
    </div>
</div>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="RegionId" />
    
    <!-- Sección 1: Información Básica -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid var(--md-sys-color-primary);">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(4, 115, 148, 0.15); display: flex; align-items: center; justify-content: center;">
                <md-icon style="color: var(--md-sys-color-primary); font-size: 28px;">location_on</md-icon>
            </div>
            <div>
                <h2 class="md-typescale-title-large" style="margin: 0;">Información Básica</h2>
                <p class="md-typescale-body-small" style="margin: 4px 0 0; color: var(--md-sys-color-on-surface-variant);">Nombre y descripción de la región</p>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <md-filled-text-field 
                    label="Nombre *" 
                    name="Nombre" 
                    required
                    value="@Model.Nombre"
                    supporting-text="Nombre único de la región">
                    <md-icon slot="leading-icon">label</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="Nombre" class="field-error"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <md-filled-text-field 
                    label="Descripción" 
                    name="Descripcion" 
                    type="textarea"
                    rows="3"
                    value="@Model.Descripcion"
                    supporting-text="Descripción breve de la región">
                    <md-icon slot="leading-icon">description</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="Descripcion" class="field-error"></span>
            </div>
        </div>
    </div>

    <!-- Form Actions -->
    <div class="form-actions" style="background: var(--md-sys-color-surface-container); padding: 24px; border-radius: 16px; box-shadow: var(--md-sys-elevation-level2);">
        <md-text-button onclick="window.location.href='@Url.Action("Index")'; return false;">
            <md-icon slot="icon">cancel</md-icon>
            Cancelar
        </md-text-button>
        <md-filled-button type="submit" style="height: 48px; min-width: 160px;">
            <md-icon slot="icon">save</md-icon>
            Guardar Cambios
        </md-filled-button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('form');
            if (!form) return;
            
            const originalData = {};
            new FormData(form).forEach((value, key) => originalData[key] = value);
            
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const currentData = {};
                new FormData(form).forEach((value, key) => currentData[key] = value);
                
                if (await showEditConfirmationDialog(originalData, currentData, 'Región')) {
                    form.removeEventListener('submit', arguments.callee);
                    if (window.syncMdTextFields) syncMdTextFields(form);
                    form.submit();
                }
            });
        });
    </script>
}
