@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Text.Json
@{
    ViewData["Title"] = "Salida sin registro";
    var categorias = (IEnumerable<SelectListItem>)(ViewBag.Categorias ?? new List<SelectListItem>());
    var departamentos = (IEnumerable<SelectListItem>)(ViewBag.Departamentos ?? new List<SelectListItem>());
    var regiones = (IEnumerable<SelectListItem>)(ViewBag.Regiones ?? new List<SelectListItem>());
}

<div style="margin-bottom:16px; display:flex; align-items:center; gap:8px; color:var(--md-sys-color-on-surface-variant); font-size:14px;">
    <md-icon style="font-size:18px;">home</md-icon>
    <span>Operaciones</span>
    <md-icon style="font-size:18px;">chevron_right</md-icon>
    <span style="color:var(--md-sys-color-primary);">Salida sin registro</span>
</div>

<div class="page-header">
    <div>
        <h1 class="md-typescale-display-small" style="margin:0 0 8px;">Salida sin registro de inventario</h1>
        <p class="md-typescale-body-large" style="color:var(--md-sys-color-on-surface-variant); margin:0;">
            Registra artículos nuevos y envíalos directo a sucursal cuando aún no existían en inventario.
        </p>
    </div>
    <md-filled-button id="btn-procesar">
        <md-icon slot="icon">send</md-icon>
        Procesar salida
    </md-filled-button>
</div>

<style>
    .salida-table-field md-filled-text-field {
        width: 100%;
        --md-filled-text-field-container-height: 44px;
    }
</style>

<div class="card" style="margin-bottom:20px;">
    <h3 class="md-typescale-title-medium" style="margin:0 0 16px; display:flex; align-items:center; gap:8px;">
        <md-icon>assignment_ind</md-icon>
        Datos generales
    </h3>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:16px;">
        <div>
            <p class="step-label" style="margin:0 0 8px;">Paso 1 — Departamento</p>
            <div class="select-with-search">
                <div class="md3-select-field has-leading-icon">
                    <md-icon class="md3-select-leading-icon">business_center</md-icon>
                    <select id="selectDepartamento" class="md3-select">
                        <option value="">Todos los departamentos</option>
                        @foreach (var d in departamentos)
                        {
                            <option value="@d.Value">@d.Text</option>
                        }
                    </select>
                    <label class="md3-select-label">Departamento</label>
                </div>
                <md-icon-button type="button" onclick="openSearchDialog('selectDepartamento','Buscar Departamento','Escribe el nombre...')" title="Buscar">
                    <md-icon>search</md-icon>
                </md-icon-button>
                <md-icon-button id="btnCrearDepartamento" type="button" onclick="crearDepartamentoRapido()" title="Agregar departamento">
                    <md-icon>add</md-icon>
                </md-icon-button>
            </div>
        </div>

        <div>
            <p class="step-label" style="margin:0 0 8px;">Paso 2 — Región</p>
            <div class="select-with-search">
                <div class="md3-select-field has-leading-icon">
                    <md-icon class="md3-select-leading-icon">public</md-icon>
                    <select id="selectRegion" class="md3-select" onchange="onRegionChange(this)">
                        <option value="">Seleccione región</option>
                        @foreach (var r in regiones)
                        {
                            <option value="@r.Value">@r.Text</option>
                        }
                    </select>
                    <label class="md3-select-label">Región</label>
                </div>
                <md-icon-button id="btnBuscarRegion" type="button" onclick="openSearchDialog('selectRegion','Buscar Región','Escribe el nombre...')" title="Buscar">
                    <md-icon>search</md-icon>
                </md-icon-button>
                <md-icon-button id="btnCrearRegion" type="button" onclick="crearRegionRapida()" title="Agregar región">
                    <md-icon>add</md-icon>
                </md-icon-button>
            </div>
        </div>

        <div>
            <p class="step-label" style="margin:0 0 8px;">Paso 3 — Sucursal</p>
            <div class="select-with-search">
                <div class="md3-select-field has-leading-icon">
                    <md-icon class="md3-select-leading-icon">store</md-icon>
                    <select id="sucursalDestinoId" class="md3-select" disabled>
                        <option value="">Seleccione primero una región</option>
                    </select>
                    <label class="md3-select-label">Sucursal destino</label>
                </div>
                <md-icon-button id="btnBuscarSucursal" type="button" disabled
                                onclick="openSearchDialog('sucursalDestinoId','Buscar Sucursal','Escribe el nombre...')" title="Buscar">
                    <md-icon>search</md-icon>
                </md-icon-button>
                <md-icon-button id="btnCrearSucursal" type="button" disabled
                                onclick="crearSucursalRapida()" title="Agregar sucursal">
                    <md-icon>add</md-icon>
                </md-icon-button>
            </div>
        </div>

        <div>
            <p class="step-label" style="margin:0 0 8px;">Responsable de recepción</p>
            <md-filled-text-field id="responsableEmpleado" label="Responsable de recepción" style="width:100%;">
                <md-icon slot="leading-icon">badge</md-icon>
            </md-filled-text-field>
        </div>

        <div style="grid-column: 1 / -1;">
            <div style="display:flex; align-items:center; gap:8px; margin:0 0 8px;">
                <md-checkbox id="entregaDepartamento"></md-checkbox>
                <label for="entregaDepartamento" class="md-typescale-body-medium" style="cursor:pointer;">
                    Entregar a departamento (sin sucursal)
                </label>
            </div>
            <div id="departamentoEntregaFields" style="display:none; margin-bottom:12px;">
                <md-filled-text-field id="personaEntregaDepartamento" label="Persona que recibe en departamento" supporting-text="Opcional" style="width:100%;">
                    <md-icon slot="leading-icon">person</md-icon>
                </md-filled-text-field>
            </div>
        </div>

        <div style="grid-column: 1 / -1;">
            <p class="step-label" style="margin:0 0 8px;">Observaciones</p>
            <md-filled-text-field id="observaciones" label="Observaciones" supporting-text="Opcional" style="width:100%;">
                <md-icon slot="leading-icon">notes</md-icon>
            </md-filled-text-field>
        </div>
    </div>
</div>

<div class="card">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
        <h3 class="md-typescale-title-medium" style="margin:0; display:flex; align-items:center; gap:8px;">
            <md-icon>inventory_2</md-icon>
            Items a registrar
        </h3>
        <md-filled-tonal-button id="btn-agregar-item">
            <md-icon slot="icon">add</md-icon>
            Agregar ítem
        </md-filled-tonal-button>
    </div>

    <div class="data-table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:48px;">#</th>
                    <th>Marca</th>
                    <th>Modelo</th>
                    <th>Descripción</th>
                    <th>Categoría</th>
                    <th>Serial</th>
                    <th style="width:100px;">Cantidad</th>
                    <th class="actions-column"></th>
                </tr>
            </thead>
            <tbody id="items-body"></tbody>
        </table>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        const categorias = @Html.Raw(JsonSerializer.Serialize(categorias.Select(c => new { value = c.Value, text = c.Text })));
        const itemsBody = document.getElementById('items-body');
        const btnAgregar = document.getElementById('btn-agregar-item');
        const btnProcesar = document.getElementById('btn-procesar');

        function categoriaOptions(selectedValue = '') {
            const defaultOption = `<option value="">Seleccione...</option>`;
            const options = categorias.map(c => `<option value="${c.value}" ${String(c.value) === String(selectedValue) ? 'selected' : ''}>${c.text}</option>`).join('');
            return defaultOption + options;
        }

        function addRow(data = {}) {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td class="row-index"></td>
                <td class="salida-table-field">
                    <md-filled-text-field class="item-marca" label="Marca" value="${data.marca ?? ''}"></md-filled-text-field>
                </td>
                <td class="salida-table-field">
                    <md-filled-text-field class="item-modelo" label="Modelo" value="${data.modelo ?? ''}"></md-filled-text-field>
                </td>
                <td class="salida-table-field">
                    <md-filled-text-field class="item-descripcion" label="Descripción" value="${data.descripcion ?? ''}"></md-filled-text-field>
                </td>
                <td>
                    <div class="md3-select-field">
                        <select class="md3-select item-categoria">${categoriaOptions(data.categoriaId)}</select>
                        <label class="md3-select-label">Categoría *</label>
                    </div>
                </td>
                <td class="salida-table-field">
                    <md-filled-text-field class="item-serial" label="Serial" value="${data.serial ?? ''}"></md-filled-text-field>
                </td>
                <td class="salida-table-field">
                    <md-filled-text-field type="number" min="1" class="item-cantidad" label="Cantidad" value="${data.cantidad ?? 1}"></md-filled-text-field>
                </td>
                <td class="actions-cell" style="text-align:center;">
                    <md-icon-button class="btn-remove-item" title="Quitar">
                        <md-icon>delete</md-icon>
                    </md-icon-button>
                </td>
            `;
            itemsBody.appendChild(row);
            refreshRowIndexes();
            row.querySelector('.btn-remove-item').addEventListener('click', () => {
                row.remove();
                if (!itemsBody.querySelector('tr')) addRow();
                refreshRowIndexes();
            });
        }

        function refreshRowIndexes() {
            Array.from(itemsBody.querySelectorAll('tr')).forEach((row, idx) => {
                row.querySelector('.row-index').textContent = idx + 1;
            });
        }

        function collectPayload() {
            const entregaDepartamento = document.getElementById('entregaDepartamento').checked;
            const departamentoDestinoId = Number(document.getElementById('selectDepartamento').value || 0);
            const sucursalDestinoId = document.getElementById('sucursalDestinoId').value;
            const responsableEmpleado = document.getElementById('responsableEmpleado').value.trim();
            const personaEntregaDepartamento = document.getElementById('personaEntregaDepartamento').value.trim();
            const observaciones = document.getElementById('observaciones').value.trim();
            const rows = Array.from(itemsBody.querySelectorAll('tr'));

            if (!rows.length) {
                showSnackbar('Debe agregar al menos un ítem.', 'warning');
                return null;
            }

            const items = [];
            for (let i = 0; i < rows.length; i++) {
                const row = rows[i];
                const marca = row.querySelector('.item-marca').value.trim();
                const modelo = row.querySelector('.item-modelo').value.trim();
                const descripcion = row.querySelector('.item-descripcion').value.trim();
                const categoriaId = Number(row.querySelector('.item-categoria').value);
                const serial = row.querySelector('.item-serial').value.trim();
                const cantidad = Number(row.querySelector('.item-cantidad').value);

                if (!marca || !modelo || !categoriaId || !cantidad || cantidad < 1) {
                    showSnackbar(`Revise la fila ${i + 1}: marca, modelo, categoría y cantidad son obligatorios.`, 'warning');
                    return null;
                }

                items.push({ marca, modelo, descripcion, categoriaId, serial, cantidad });
            }

            return {
                entregaDepartamento,
                departamentoDestinoId: entregaDepartamento && departamentoDestinoId ? departamentoDestinoId : null,
                personaEntregaDepartamento,
                sucursalDestinoId: entregaDepartamento ? null : sucursalDestinoId,
                responsableEmpleado,
                observaciones,
                items
            };
        }

        async function procesarSalidaSinRegistro() {
            const payload = collectPayload();
            if (!payload) return;

            const confirmed = await showConfirmDialog(
                payload.entregaDepartamento
                    ? `Se registrarán ${payload.items.length} ítem(s) nuevos y se entregarán por departamento. ¿Desea continuar?`
                    : `Se registrarán ${payload.items.length} ítem(s) nuevos y se enviarán con el destino configurado. ¿Desea continuar?`,
                'Confirmar salida sin registro'
            );
            if (!confirmed) return;

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            btnProcesar.disabled = true;
            showLoading('Procesando salida sin registro...');

            try {
                const response = await fetch('@Url.Action("Procesar", "SalidaSinRegistro")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(payload)
                });
                const result = await response.json();
                if (result.success) {
                    showSnackbar(result.message, 'success');
                    document.getElementById('entregaDepartamento').checked = false;
                    setModoEntregaDepartamento(false);
                    document.getElementById('sucursalDestinoId').value = '';
                    document.getElementById('responsableEmpleado').value = '';
                    document.getElementById('personaEntregaDepartamento').value = '';
                    document.getElementById('observaciones').value = '';
                    itemsBody.innerHTML = '';
                    addRow();
                } else {
                    showSnackbar(result.message || 'No se pudo procesar la salida sin registro.', 'error');
                }
            } catch (error) {
                showSnackbar(`Error de conexión: ${error.message}`, 'error');
            } finally {
                hideLoading();
                btnProcesar.disabled = false;
            }
        }

        function upsertSelectOption(selectEl, value, text, selectIt = true) {
            if (!selectEl) return;
            let option = Array.from(selectEl.options).find(o => o.value === String(value));
            if (!option) {
                option = document.createElement('option');
                option.value = String(value);
                option.textContent = text;
                selectEl.appendChild(option);
            } else {
                option.textContent = text;
            }
            if (selectIt) {
                selectEl.value = String(value);
                selectEl.dispatchEvent(new Event('change', { bubbles: true }));
            }
        }

        function getRequestToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        async function crearDepartamentoRapido() {
            const nombre = await showTextInputDialog('Nuevo Departamento', 'Nombre del departamento');
            if (!nombre) return;

            const resp = await fetch('/SalidaSinRegistro/CrearDepartamentoRapido', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getRequestToken()
                },
                body: JSON.stringify({ nombre })
            });
            const data = await resp.json();
            if (!data.success) {
                showSnackbar(data.message || 'No se pudo crear el departamento.', 'error');
                return;
            }

            upsertSelectOption(document.getElementById('selectDepartamento'), data.option.value, data.option.text, true);
            showSnackbar('Departamento agregado.', 'success');
        }

        async function crearRegionRapida() {
            const nombre = await showTextInputDialog('Nueva Región', 'Nombre de la región');
            if (!nombre) return;

            const resp = await fetch('/SalidaSinRegistro/CrearRegionRapida', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getRequestToken()
                },
                body: JSON.stringify({ nombre })
            });
            const data = await resp.json();
            if (!data.success) {
                showSnackbar(data.message || 'No se pudo crear la región.', 'error');
                return;
            }

            const sel = document.getElementById('selectRegion');
            upsertSelectOption(sel, data.option.value, data.option.text, true);
            showSnackbar('Región agregada.', 'success');
            await onRegionChange(sel);
        }

        async function crearSucursalRapida() {
            const regionId = document.getElementById('selectRegion')?.value;
            if (!regionId) {
                showSnackbar('Primero selecciona una región.', 'warning');
                return;
            }

            const nombre = await showTextInputDialog('Nueva Sucursal', 'Nombre de la sucursal');
            if (!nombre) return;

            const resp = await fetch('/SalidaSinRegistro/CrearSucursalRapida', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getRequestToken()
                },
                body: JSON.stringify({ nombre, regionId: Number(regionId) })
            });
            const data = await resp.json();
            if (!data.success) {
                showSnackbar(data.message || 'No se pudo crear la sucursal.', 'error');
                return;
            }

            const sel = document.getElementById('sucursalDestinoId');
            sel.disabled = false;
            document.getElementById('btnBuscarSucursal').disabled = false;
            document.getElementById('btnCrearSucursal').disabled = false;
            upsertSelectOption(sel, data.option.value, data.option.text, true);
            showSnackbar('Sucursal agregada.', 'success');
        }

        function setModoEntregaDepartamento(activo) {
            const selectRegion = document.getElementById('selectRegion');
            const sucursal = document.getElementById('sucursalDestinoId');
            const btnBuscarRegion = document.getElementById('btnBuscarRegion');
            const btnBuscarSucursal = document.getElementById('btnBuscarSucursal');
            const btnCrearRegion = document.getElementById('btnCrearRegion');
            const btnCrearSucursal = document.getElementById('btnCrearSucursal');
            const fields = document.getElementById('departamentoEntregaFields');

            fields.style.display = activo ? 'block' : 'none';

            if (activo) {
                selectRegion.value = '';
                selectRegion.disabled = true;
                btnBuscarRegion.disabled = true;
                btnCrearRegion.disabled = true;
                sucursal.innerHTML = '<option value="">No aplica para entrega por departamento</option>';
                sucursal.disabled = true;
                btnBuscarSucursal.disabled = true;
                btnCrearSucursal.disabled = true;
            } else {
                selectRegion.disabled = false;
                btnBuscarRegion.disabled = false;
                btnCrearRegion.disabled = false;
                sucursal.innerHTML = '<option value="">Seleccione primero una región</option>';
                sucursal.disabled = true;
                btnBuscarSucursal.disabled = true;
                btnCrearSucursal.disabled = !selectRegion.value;
            }
        }

        async function onRegionChange(select) {
            if (document.getElementById('entregaDepartamento').checked) {
                return;
            }
            const regionId = select.value;
            const selectSucursal = document.getElementById('sucursalDestinoId');
            const btnBuscar = document.getElementById('btnBuscarSucursal');
            const btnCrear = document.getElementById('btnCrearSucursal');

            selectSucursal.innerHTML = '<option value="">Cargando...</option>';
            selectSucursal.disabled = true;
            btnBuscar.disabled = true;
            btnCrear.disabled = true;

            if (!regionId) {
                selectSucursal.innerHTML = '<option value="">Seleccione primero una región</option>';
                return;
            }

            try {
                const resp = await fetch(`/SalidaSinRegistro/SucursalesPorRegion?regionId=${regionId}`);
                const data = await resp.json();

                selectSucursal.innerHTML = '<option value="">Seleccione sucursal destino</option>';
                data.forEach(s => {
                    const opt = document.createElement('option');
                    opt.value = s.value;
                    opt.textContent = s.text;
                    selectSucursal.appendChild(opt);
                });

                if (data.length === 0) {
                    selectSucursal.innerHTML = '<option value="">Sin sucursales en esta región</option>';
                    btnCrear.disabled = false;
                } else {
                    selectSucursal.disabled = false;
                    btnBuscar.disabled = false;
                    btnCrear.disabled = false;
                }
            } catch {
                selectSucursal.innerHTML = '<option value="">Error cargando sucursales</option>';
                showSnackbar('No se pudieron cargar las sucursales para la región seleccionada.', 'error');
            }
        }

        btnAgregar.addEventListener('click', () => addRow());
        btnProcesar.addEventListener('click', procesarSalidaSinRegistro);
        document.getElementById('entregaDepartamento').addEventListener('change', (e) => setModoEntregaDepartamento(e.target.checked));
        setModoEntregaDepartamento(false);
        addRow();
    </script>
}
