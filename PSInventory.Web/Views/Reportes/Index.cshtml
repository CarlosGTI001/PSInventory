@{
    ViewData["Title"] = "Reportes PDF";
    var categorias = ViewBag.Categorias as List<PSData.Modelos.Categoria> ?? new List<PSData.Modelos.Categoria>();
    var sucursales = ViewBag.Sucursales as List<PSData.Modelos.Sucursal> ?? new List<PSData.Modelos.Sucursal>();
}

<!-- Breadcrumb -->
<div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; color: var(--md-sys-color-on-surface-variant); font-size: 14px;">
    <md-icon style="font-size: 18px;">home</md-icon>
    <span>Inicio</span>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <span style="color: var(--md-sys-color-primary);">Reportes PDF</span>
</div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="md-typescale-display-small" style="margin: 0 0 8px 0;">Reportes PDF</h1>
        <p class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface-variant); margin: 0;">
            Genera reportes profesionales del inventario
        </p>
    </div>
    <md-icon style="font-size: 80px; color: var(--md-sys-color-primary); opacity: 0.2;">description</md-icon>
</div>

<!-- Reports Grid -->
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(500px, 1fr)); gap: 20px; margin-top: 32px;">

    <!-- 1. INVENTARIO GENERAL -->
    <div class="card" style="transition: all 0.3s ease;">
        <!-- Card Header with Icon -->
        <div style="background: linear-gradient(135deg, #047394 0%, #0589ab 100%); padding: 24px; color: white; display: flex; align-items: center; gap: 16px;">
            <div style="background: rgba(255,255,255,0.2); border-radius: 12px; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
                <md-icon style="font-size: 32px;">inventory_2</md-icon>
            </div>
            <div>
                <h3 class="md-typescale-title-large" style="margin: 0; color: white;">Inventario General</h3>
                <p style="margin: 4px 0 0 0; opacity: 0.9; font-size: 14px;">Reporte completo de todos los items</p>
            </div>
        </div>

        <!-- Card Content -->
        <div style="padding: 24px;">
            <div style="display: flex; flex-direction: column; gap: 16px;">
                <!-- Filters Row 1 -->
                <div class="form-row">
                    <div style="flex: 1;">
                        <md-filled-select label="Estado" id="ig-estado">
                            <md-select-option value=""></md-select-option>
                            <md-select-option value="Disponible">Disponible</md-select-option>
                            <md-select-option value="Asignado">Asignado</md-select-option>
                            <md-select-option value="En Reparación">En Reparación</md-select-option>
                            <md-select-option value="Baja">Baja</md-select-option>
                        </md-filled-select>
                    </div>
                </div>

                <!-- Filters Row 2 -->
                <div class="form-row">
                    <div style="flex: 1;">
                        <md-filled-select label="Categoría" id="ig-categoria">
                            <md-select-option value=""></md-select-option>
                            @foreach (var cat in categorias)
                            {
                                <md-select-option value="@cat.Id">@cat.Nombre</md-select-option>
                            }
                        </md-filled-select>
                    </div>
                </div>

                <!-- Filters Row 3 -->
                <div class="form-row">
                    <div style="flex: 1;">
                        <md-filled-select label="Sucursal" id="ig-sucursal">
                            <md-select-option value=""></md-select-option>
                            @foreach (var suc in sucursales)
                            {
                                <md-select-option value="@suc.Id">@suc.Nombre</md-select-option>
                            }
                        </md-filled-select>
                    </div>
                </div>

                <!-- Submit Button -->
                <div style="display: flex; justify-content: center; margin-top: 8px;">
                    <md-filled-button style="background-color: #047394;" onclick="generarInventarioGeneral()">
                        <md-icon slot="icon">picture_as_pdf</md-icon>
                        Generar PDF
                    </md-filled-button>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. INVENTARIO POR SUCURSAL -->
    <div class="card" style="transition: all 0.3s ease;">
        <!-- Card Header with Icon -->
        <div style="background: linear-gradient(135deg, #ff5c00 0%, #ff7f2c 100%); padding: 24px; color: white; display: flex; align-items: center; gap: 16px;">
            <div style="background: rgba(255,255,255,0.2); border-radius: 12px; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
                <md-icon style="font-size: 32px;">store</md-icon>
            </div>
            <div>
                <h3 class="md-typescale-title-large" style="margin: 0; color: white;">Inventario por Sucursal</h3>
                <p style="margin: 4px 0 0 0; opacity: 0.9; font-size: 14px;">Items detallados por sucursal</p>
            </div>
        </div>

        <!-- Card Content -->
        <div style="padding: 24px;">
            <div style="display: flex; flex-direction: column; gap: 16px;">
                <!-- Filters -->
                <div class="form-row">
                    <div style="flex: 1;">
                        <md-filled-select label="Sucursal *" required id="ips-sucursal">
                            <md-select-option value=""></md-select-option>
                            @foreach (var suc in sucursales)
                            {
                                <md-select-option value="@suc.Id">@suc.Nombre</md-select-option>
                            }
                        </md-filled-select>
                    </div>
                </div>

                <!-- Submit Button -->
                <div style="display: flex; justify-content: center; margin-top: 8px;">
                    <md-filled-button style="background-color: #ff5c00;" onclick="generarInventarioPorSucursal()">
                        <md-icon slot="icon">picture_as_pdf</md-icon>
                        Generar PDF
                    </md-filled-button>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. MOVIMIENTOS DE ITEMS -->
    <div class="card" style="transition: all 0.3s ease;">
        <!-- Card Header with Icon -->
        <div style="background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%); padding: 24px; color: white; display: flex; align-items: center; gap: 16px;">
            <div style="background: rgba(255,255,255,0.2); border-radius: 12px; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
                <md-icon style="font-size: 32px;">swap_horiz</md-icon>
            </div>
            <div>
                <h3 class="md-typescale-title-large" style="margin: 0; color: white;">Movimientos de Items</h3>
                <p style="margin: 4px 0 0 0; opacity: 0.9; font-size: 14px;">Historial de transferencias y movimientos</p>
            </div>
        </div>

        <!-- Card Content -->
        <div style="padding: 24px;">
            <form action="/Reportes/MovimientosItems" method="get" target="_blank" style="display: flex; flex-direction: column; gap: 16px;" id="formMovimientos">
                <!-- Filters Row 1 -->
                <div class="form-row">
                    <div style="flex: 1;">
                        <md-filled-text-field label="Fecha Inicio" type="date" name="fechaInicio"></md-filled-text-field>
                    </div>
                    <div style="flex: 1;">
                        <md-filled-text-field label="Fecha Fin" type="date" name="fechaFin"></md-filled-text-field>
                    </div>
                </div>

                <!-- Filters Row 2 -->
                <div class="form-row">
                    <div style="flex: 1;">
                        <md-filled-select label="Sucursal (Opcional)" id="mov-sucursal">
                            <md-select-option value=""></md-select-option>
                            @foreach (var suc in sucursales)
                            {
                                <md-select-option value="@suc.Id">@suc.Nombre</md-select-option>
                            }
                        </md-filled-select>
                    </div>
                </div>

                <!-- Submit Button -->
                <div style="display: flex; justify-content: center; margin-top: 8px;">
                    <md-filled-button style="background-color: #7c3aed;" onclick="generarMovimientos(event)">
                        <md-icon slot="icon">picture_as_pdf</md-icon>
                        Generar PDF
                    </md-filled-button>
                </div>
            </form>
        </div>
    </div>

    <!-- 4. ITEMS GARANTÍA POR VENCER -->
    <div class="card" style="transition: all 0.3s ease;">
        <!-- Card Header with Icon -->
        <div style="background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%); padding: 24px; color: white; display: flex; align-items: center; gap: 16px;">
            <div style="background: rgba(255,255,255,0.2); border-radius: 12px; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
                <md-icon style="font-size: 32px;">schedule</md-icon>
            </div>
            <div>
                <h3 class="md-typescale-title-large" style="margin: 0; color: white;">Items Garantía por Vencer</h3>
                <p style="margin: 4px 0 0 0; opacity: 0.9; font-size: 14px;">Garantías próximas a expirar</p>
            </div>
        </div>

        <!-- Card Content -->
        <div style="padding: 24px;">
            <form action="/Reportes/ItemsGarantiaPorVencer" method="get" target="_blank" style="display: flex; flex-direction: column; gap: 16px;">
                <!-- Filters -->
                <div class="form-row">
                    <div style="flex: 1;">
                        <md-filled-text-field label="Días de Anticipación" type="number" name="diasAnticipacion" value="30"></md-filled-text-field>
                    </div>
                </div>

                <p style="font-size: 12px; color: var(--md-sys-color-on-surface-variant); margin: 0; text-align: center;">
                    Mostrará items con garantía que vence en los próximos días especificados
                </p>

                <!-- Submit Button -->
                <div style="display: flex; justify-content: center; margin-top: 8px;">
                    <md-filled-button type="submit" style="background-color: #f59e0b;">
                        <md-icon slot="icon">picture_as_pdf</md-icon>
                        Generar PDF
                    </md-filled-button>
                </div>
            </form>
        </div>
    </div>

    <!-- 5. REPORTE DE COMPRAS -->
    <div class="card" style="transition: all 0.3s ease;">
        <!-- Card Header with Icon -->
        <div style="background: linear-gradient(135deg, #10b981 0%, #34d399 100%); padding: 24px; color: white; display: flex; align-items: center; gap: 16px;">
            <div style="background: rgba(255,255,255,0.2); border-radius: 12px; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
                <md-icon style="font-size: 32px;">shopping_cart</md-icon>
            </div>
            <div>
                <h3 class="md-typescale-title-large" style="margin: 0; color: white;">Reporte de Compras</h3>
                <p style="margin: 4px 0 0 0; opacity: 0.9; font-size: 14px;">Análisis de compras realizadas</p>
            </div>
        </div>

        <!-- Card Content -->
        <div style="padding: 24px;">
            <form action="/Reportes/ReporteCompras" method="get" target="_blank" style="display: flex; flex-direction: column; gap: 16px;">
                <!-- Filters -->
                <div class="form-row">
                    <div style="flex: 1;">
                        <md-filled-text-field label="Fecha Inicio" type="date" name="fechaInicio"></md-filled-text-field>
                    </div>
                    <div style="flex: 1;">
                        <md-filled-text-field label="Fecha Fin" type="date" name="fechaFin"></md-filled-text-field>
                    </div>
                </div>

                <!-- Submit Button -->
                <div style="display: flex; justify-content: center; margin-top: 8px;">
                    <md-filled-button type="submit" style="background-color: #10b981;">
                        <md-icon slot="icon">picture_as_pdf</md-icon>
                        Generar PDF
                    </md-filled-button>
                </div>
            </form>
        </div>
    </div>

    <!-- 6. ESTADÍSTICAS GENERALES -->
    <div class="card" style="transition: all 0.3s ease;">
        <!-- Card Header with Icon -->
        <div style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); padding: 24px; color: white; display: flex; align-items: center; gap: 16px;">
            <div style="background: rgba(255,255,255,0.2); border-radius: 12px; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
                <md-icon style="font-size: 32px;">analytics</md-icon>
            </div>
            <div>
                <h3 class="md-typescale-title-large" style="margin: 0; color: white;">Estadísticas Generales</h3>
                <p style="margin: 4px 0 0 0; opacity: 0.9; font-size: 14px;">Resumen estadístico del inventario</p>
            </div>
        </div>

        <!-- Card Content -->
        <div style="padding: 24px;">
            <form action="/Reportes/EstadisticasGenerales" method="get" target="_blank" style="display: flex; flex-direction: column; gap: 16px;">
                <p style="font-size: 14px; color: var(--md-sys-color-on-surface-variant); margin: 0; text-align: center;">
                    <md-icon style="font-size: 20px; vertical-align: middle;">info</md-icon>
                    Este reporte no requiere filtros. Mostrará estadísticas generales de todo el inventario.
                </p>

                <!-- Submit Button -->
                <div style="display: flex; justify-content: center; margin-top: 8px;">
                    <md-filled-button type="submit" style="background-color: #6366f1;">
                        <md-icon slot="icon">picture_as_pdf</md-icon>
                        Generar PDF
                    </md-filled-button>
                </div>
            </form>
        </div>
    </div>

</div>

<style>
    .card {
        background: var(--md-sys-color-surface);
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    .card:hover {
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
        transform: translateY(-2px);
    }

    .form-row {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .form-row > div {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    md-filled-select,
    md-filled-text-field {
        width: 100%;
    }

    md-filled-button {
        width: 100%;
        max-width: 200px;
    }

    @@media (max-width: 768px) {
        div[style*="grid-template-columns: repeat(auto-fit, minmax(500px"] {
            grid-template-columns: 1fr !important;
        }
    }
</style>

<script>
    function getSelectValue(id) {
        return document.getElementById(id)?.value ?? '';
    }

    function buildUrl(base, params) {
        const query = Object.entries(params)
            .filter(([, v]) => v)
            .map(([k, v]) => `${encodeURIComponent(k)}=${encodeURIComponent(v)}`)
            .join('&');
        return query ? `${base}?${query}` : base;
    }

    function generarInventarioGeneral() {
        const url = buildUrl('/Reportes/InventarioGeneral', {
            estado:      getSelectValue('ig-estado'),
            categoriaId: getSelectValue('ig-categoria'),
            sucursalId:  getSelectValue('ig-sucursal')
        });
        window.open(url, '_blank');
    }

    function generarInventarioPorSucursal() {
        const sucursalId = getSelectValue('ips-sucursal');
        if (!sucursalId) { alert('Selecciona una sucursal.'); return; }
        window.open(`/Reportes/InventarioPorSucursal?sucursalId=${encodeURIComponent(sucursalId)}`, '_blank');
    }

    function generarMovimientos(e) {
        e.preventDefault();
        const form = document.getElementById('formMovimientos');
        const params = new URLSearchParams();
        form.querySelectorAll('[name]').forEach(el => { if (el.value) params.set(el.name, el.value); });
        const sucursal = getSelectValue('mov-sucursal');
        if (sucursal) params.set('sucursalId', sucursal);
        window.open(`/Reportes/MovimientosItems?${params.toString()}`, '_blank');
    }
</script>
