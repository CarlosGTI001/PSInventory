@model PSData.Modelos.Item

@{
    ViewData["Title"] = "Editar Item";
}

<!-- Breadcrumb -->
<div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; color: var(--md-sys-color-on-surface-variant); font-size: 14px;">
    <md-icon style="font-size: 18px;">home</md-icon>
    <span>Inventario</span>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <a href="@Url.Action("Index")" style="color: var(--md-sys-color-on-surface-variant); text-decoration: none;">Items</a>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <span style="color: var(--md-sys-color-primary);">Editar: @Model.Serial</span>
</div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="md-typescale-display-small" style="margin: 0 0 8px 0;">Editar Item</h1>
        <p class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface-variant); margin: 0;">
            Modificar información del item <strong>@Model.Serial</strong>
        </p>
    </div>
</div>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Serial" />
    
    <!-- Sección 1: Información Básica -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid var(--md-sys-color-primary);">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(4, 115, 148, 0.15); display: flex; align-items: center; justify-content: center;">
                <md-icon style="color: var(--md-sys-color-primary); font-size: 28px;">qr_code_scanner</md-icon>
            </div>
            <div>
                <h2 class="md-typescale-title-large" style="margin: 0;">Información Básica</h2>
                <p class="md-typescale-body-small" style="margin: 4px 0 0; color: var(--md-sys-color-on-surface-variant);">Identificación y datos generales del item</p>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <md-filled-text-field 
                    label="Número de Serie" 
                    name="SerialDisplay" 
                    value="@Model.Serial"
                    disabled
                    supporting-text="El número de serie no se puede modificar">
                    <md-icon slot="leading-icon">qr_code</md-icon>
                </md-filled-text-field>
            </div>
            
            <div class="form-field">
                <md-filled-text-field 
                    label="Costo *" 
                    name="Costo" 
                    type="number"
                    step="0.01"
                    required
                    value="@Model.Costo"
                    supporting-text="Precio de adquisición del item">
                    <md-icon slot="leading-icon">attach_money</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="Costo" class="field-error"></span>
            </div>
        </div>
        
        <div class="form-row">
            <div class="form-field">
                <div class="md3-select-field has-leading-icon">
                    <md-icon class="md3-select-leading-icon">devices</md-icon>
                    <select asp-for="ArticuloId" class="md3-select" required>
                        <option value="">Seleccione un artículo</option>
                        @foreach (var articulo in ViewBag.Articulos)
                        {
                            <option value="@articulo.Value" selected="@(Model.ArticuloId.ToString() == articulo.Value)">@articulo.Text</option>
                        }
                    </select>
                    <label class="md3-select-label">Artículo *</label>
                </div>
                <p class="md3-select-supporting">Modelo del artículo</p>
                <span asp-validation-for="ArticuloId" class="field-error"></span>
            </div>
            
            <div class="form-field">
                <div class="md3-select-field has-leading-icon">
                    <md-icon class="md3-select-leading-icon">shopping_cart</md-icon>
                    <select asp-for="CompraId" class="md3-select" required>
                        <option value="">Seleccione una compra</option>
                        @foreach (var compra in ViewBag.Compras)
                        {
                            <option value="@compra.Value" selected="@(Model.CompraId.ToString() == compra.Value)">@compra.Text</option>
                        }
                    </select>
                    <label class="md3-select-label">Orden de Compra *</label>
                </div>
                <p class="md3-select-supporting">Compra asociada a este item</p>
                <span asp-validation-for="CompraId" class="field-error"></span>
            </div>
        </div>
    </div>

    <!-- Sección 2: Asignación -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid var(--md-sys-color-secondary);">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(255, 92, 0, 0.15); display: flex; align-items: center; justify-content: center;">
                <md-icon style="color: var(--md-sys-color-secondary); font-size: 28px;">store</md-icon>
            </div>
            <div>
                <h2 class="md-typescale-title-large" style="margin: 0;">Asignación y Estado</h2>
                <p class="md-typescale-body-small" style="margin: 4px 0 0; color: var(--md-sys-color-on-surface-variant);">Ubicación actual y estado del item</p>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <div class="md3-select-field has-leading-icon">
                    <md-icon class="md3-select-leading-icon">store</md-icon>
                    <select asp-for="SucursalId" class="md3-select">
                        <option value="">Sin asignar (Disponible en almacén)</option>
                        @foreach (var sucursal in ViewBag.Sucursales)
                        {
                            <option value="@sucursal.Value" selected="@(Model.SucursalId == sucursal.Value)">@sucursal.Text</option>
                        }
                    </select>
                    <label class="md3-select-label">Sucursal</label>
                </div>
                <p class="md3-select-supporting">Dejar vacío si el item está disponible</p>
                <span asp-validation-for="SucursalId" class="field-error"></span>
            </div>
            
            <div class="form-field">
                <div class="md3-select-field has-leading-icon">
                    <md-icon class="md3-select-leading-icon">info</md-icon>
                    <select asp-for="Estado" class="md3-select" required>
                        <option value="Disponible" selected="@(Model.Estado == "Disponible")">Disponible</option>
                        <option value="Asignado" selected="@(Model.Estado == "Asignado")">Asignado</option>
                        <option value="En Reparación" selected="@(Model.Estado == "En Reparación")">En Reparación</option>
                        <option value="Baja" selected="@(Model.Estado == "Baja")">Baja</option>
                    </select>
                    <label class="md3-select-label">Estado *</label>
                </div>
                <span asp-validation-for="Estado" class="field-error"></span>
            </div>
        </div>
    </div>

    <!-- Sección 3: Garantía -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid var(--md-sys-color-tertiary);">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(91, 201, 229, 0.15); display: flex; align-items: center; justify-content: center;">
                <md-icon style="color: var(--md-sys-color-tertiary); font-size: 28px;">verified</md-icon>
            </div>
            <div>
                <h2 class="md-typescale-title-large" style="margin: 0;">Información de Garantía</h2>
                <p class="md-typescale-body-small" style="margin: 4px 0 0; color: var(--md-sys-color-on-surface-variant);">Datos de la garantía del fabricante</p>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <md-filled-text-field 
                    label="Fecha de Inicio" 
                    name="FechaGarantiaInicio" 
                    type="date"
                    value="@Model.FechaGarantiaInicio?.ToString("yyyy-MM-dd")"
                    supporting-text="Fecha de inicio de la garantía">
                    <md-icon slot="leading-icon">event</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="FechaGarantiaInicio" class="field-error"></span>
            </div>
            
            <div class="form-field">
                <md-filled-text-field 
                    label="Meses de Garantía" 
                    name="MesesGarantia" 
                    type="number"
                    value="@Model.MesesGarantia"
                    supporting-text="Duración de la garantía en meses">
                    <md-icon slot="leading-icon">schedule</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="MesesGarantia" class="field-error"></span>
            </div>
        </div>
    </div>

    <!-- Sección 4: Observaciones -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px;">
            <md-icon style="color: var(--md-sys-color-on-surface-variant); font-size: 28px;">description</md-icon>
            <div>
                <h2 class="md-typescale-title-large" style="margin: 0;">Observaciones Adicionales</h2>
                <p class="md-typescale-body-small" style="margin: 4px 0 0; color: var(--md-sys-color-on-surface-variant);">Notas o comentarios sobre el item</p>
            </div>
        </div>

        <div class="form-field">
            <md-filled-text-field 
                label="Observaciones" 
                name="Observaciones" 
                type="textarea"
                rows="4"
                value="@Model.Observaciones"
                supporting-text="Información adicional relevante (opcional)">
                <md-icon slot="leading-icon">note</md-icon>
            </md-filled-text-field>
            <span asp-validation-for="Observaciones" class="field-error"></span>
        </div>
    </div>

    <!-- Form Actions -->
    <div class="form-actions" style="background: var(--md-sys-color-surface-container); padding: 24px; border-radius: 16px; box-shadow: var(--md-sys-elevation-level2);">
        <md-text-button onclick="window.location.href='@Url.Action("Index")'; return false;">
            <md-icon slot="icon">cancel</md-icon>
            Cancelar
        </md-text-button>
        <md-filled-button type="submit" style="height: 48px; min-width: 160px;">
            <md-icon slot="icon">save</md-icon>
            Guardar Cambios
        </md-filled-button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
