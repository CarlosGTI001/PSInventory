@model IEnumerable<PSData.Modelos.Region>

@{
    ViewData["Title"] = "Regiones";
    var totalRegiones = Model.Count();
}

<!-- Breadcrumb -->
<div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; color: var(--md-sys-color-on-surface-variant); font-size: 14px;">
    <md-icon style="font-size: 18px;">home</md-icon>
    <span>Configuración</span>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <span style="color: var(--md-sys-color-primary);">Regiones</span>
</div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="md-typescale-display-small" style="margin: 0 0 8px 0;">Regiones Geográficas</h1>
        <p class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface-variant); margin: 0;">
            Administra las regiones donde se ubican las sucursales
        </p>
    </div>
    <md-filled-button onclick="window.location.href='@Url.Action("Create")'">
        <md-icon slot="icon">add</md-icon>
        Nueva Región
    </md-filled-button>
</div>

<!-- Stats Cards -->
<div class="stats-grid" style="margin-bottom: 32px;">
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value">@totalRegiones</div>
                <div class="stat-card-label">Total Regiones</div>
            </div>
            <div class="stat-card-icon">
                <md-icon>public</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-success);">@Model.Count(r => !string.IsNullOrEmpty(r.Descripcion))</div>
                <div class="stat-card-label">Con Descripción</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(76, 175, 80, 0.15);">
                <md-icon style="color: var(--md-sys-color-success);">description</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-secondary);">@totalRegiones</div>
                <div class="stat-card-label">Activas</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(255, 92, 0, 0.15);">
                <md-icon style="color: var(--md-sys-color-secondary);">location_on</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-primary);">100%</div>
                <div class="stat-card-label">Cobertura</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(4, 115, 148, 0.15);">
                <md-icon style="color: var(--md-sys-color-primary);">map</md-icon>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <md-icon>check_circle</md-icon>
        <span>@TempData["Success"]</span>
    </div>
}

<!-- Data Table -->
<div class="card">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <md-icon style="color: var(--md-sys-color-primary);">table_chart</md-icon>
            <h3 class="md-typescale-title-medium" style="margin: 0;">Lista de Regiones</h3>
        </div>
        <span class="md-typescale-body-medium" style="color: var(--md-sys-color-on-surface-variant);">
            @totalRegiones región@(totalRegiones != 1 ? "es" : "") registrada@(totalRegiones != 1 ? "s" : "")
        </span>
    </div>

    <div class="data-table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th class="actions-column">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <md-icon style="color: var(--md-sys-color-secondary); font-size: 20px;">place</md-icon>
                                <strong>@item.Nombre</strong>
                            </div>
                        </td>
                        <td>@item.Descripcion</td>
                        <td class="actions-cell">
                            <md-icon-button onclick="window.location.href='@Url.Action("Edit", new { id = item.Id })'">
                                <md-icon>edit</md-icon>
                            </md-icon-button>
                            <md-icon-button onclick="confirmDelete(@item.Id, '@item.Nombre')">
                                <md-icon>delete</md-icon>
                            </md-icon-button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <md-icon style="font-size: 64px; color: var(--md-sys-color-outline);">location_on</md-icon>
        <h3 class="md-typescale-headline-small">No hay regiones registradas</h3>
        <p class="md-typescale-body-medium">Comienza creando tu primera región</p>
        <md-filled-button onclick="window.location.href='@Url.Action("Create")'">
            <md-icon slot="icon">add</md-icon>
            Crear Región
        </md-filled-button>
    </div>
}

@section Scripts {
    <script>
        async function confirmDelete(id, nombre) {
            if (await showConfirmDialog(
                'Eliminar Región',
                `¿Estás seguro de eliminar la región "${nombre}"?`,
                'Eliminar'
            )) {
                const formData = new FormData();
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
                
                const response = await fetch(`@Url.Action("Delete")/` + id, {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showSnackbar(result.message, 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showSnackbar(result.message, 'error');
                }
            }
        }
    </script>
    @Html.AntiForgeryToken()
}
