@model IEnumerable<PSData.Modelos.Compra>

@{
    ViewData["Title"] = "Compras";
    var compras = Model.ToList();
    var totalCompras = ViewBag.TotalCount != null ? (int)ViewBag.TotalCount : compras.Count;
    var pendientes = compras.Count(c => c.Estado == "Pendiente");
    var completadas = compras.Count(c => c.Estado == "Completada");
    var canceladas = compras.Count(c => c.Estado == "Cancelada");
    var costoTotal = compras.Sum(c => c.CostoTotal);
    var q = ViewBag.Query as string ?? "";
    var currentPage = ViewBag.Page != null ? (int)ViewBag.Page : 1;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var pageSize = ViewBag.PageSize != null ? (int)ViewBag.PageSize : 20;
}

<!-- Breadcrumb -->
<div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; color: var(--md-sys-color-on-surface-variant); font-size: 14px;">
    <md-icon style="font-size: 18px;">home</md-icon>
    <span>Inventario</span>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <span style="color: var(--md-sys-color-primary);">Compras</span>
</div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="md-typescale-display-small" style="margin: 0 0 8px 0;">Compras de Inventario</h1>
        <p class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface-variant); margin: 0;">
            Gestiona las compras y órdenes de inventario
        </p>
    </div>
    <md-filled-button onclick="window.location.href='@Url.Action("Create")'">
        <md-icon slot="icon">add</md-icon>
        Nueva Compra
    </md-filled-button>
</div>

<!-- Stats Cards -->
<div class="stats-grid" style="margin-bottom: 32px;">
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value">@totalCompras</div>
                <div class="stat-card-label">Total Compras</div>
            </div>
            <div class="stat-card-icon">
                <md-icon>shopping_cart</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-warning);">@pendientes</div>
                <div class="stat-card-label">Pendientes</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(255, 152, 0, 0.15);">
                <md-icon style="color: var(--md-sys-color-warning);">schedule</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-success);">@completadas</div>
                <div class="stat-card-label">Completadas</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(76, 175, 80, 0.15);">
                <md-icon style="color: var(--md-sys-color-success);">check_circle</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value">$@costoTotal.ToString("N0")</div>
                <div class="stat-card-label">Inversión Total</div>
            </div>
            <div class="stat-card-icon">
                <md-icon>attach_money</md-icon>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <md-icon>check_circle</md-icon>
        <span>@TempData["Success"]</span>
    </div>
}

<div class="card" style="margin-bottom: 20px;">
    <form method="get" action="@Url.Action("Index")" style="display:flex; gap:12px; align-items:end; flex-wrap:wrap;">
        <md-filled-text-field name="q" label="Buscar proveedor, factura o estado" value="@q" style="min-width:320px;">
            <md-icon slot="leading-icon">search</md-icon>
        </md-filled-text-field>
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="@pageSize" />
        <md-filled-button type="submit"><md-icon slot="icon">search</md-icon>Filtrar</md-filled-button>
        <md-text-button onclick="window.location.href='@Url.Action("Index")'; return false;">Limpiar</md-text-button>
    </form>
</div>

<!-- Cards View -->
<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 20px;">
    @foreach (var compra in compras.OrderByDescending(c => c.FechaCompra))
    {
        var estadoColor = compra.Estado switch {
            "Completada" => "var(--md-sys-color-success)",
            "Pendiente" => "var(--md-sys-color-warning)",
            "Cancelada" => "var(--md-sys-color-error)",
            _ => "var(--md-sys-color-outline)"
        };
        var estadoIcon = compra.Estado switch {
            "Completada" => "check_circle",
            "Pendiente" => "schedule",
            "Cancelada" => "cancel",
            _ => "info"
        };
        var itemsCount = compra.Lotes?.Sum(l => l.Items?.Count ?? 0) ?? 0;

        <div class="card" style="padding: 0; overflow: hidden; transition: all 0.3s ease; cursor: pointer;" 
                          onclick="window.location.href='@Url.Action("Details", new { id = compra.Id })'"
                          onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 16px rgba(0,0,0,0.15)'" 
                          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow=''">
            <!-- Card Header -->
            <div style="background: linear-gradient(135deg, var(--md-sys-color-primary) 0%, #0589ab 100%); padding: 24px; color: white;">
                <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 12px;">
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <md-icon style="font-size: 28px;">receipt_long</md-icon>
                        <div>
                            <div class="md-typescale-title-medium" style="font-weight: 600;">Compra #@compra.Id</div>
                            <div style="font-size: 14px; opacity: 0.9; margin-top: 4px;">@compra.FechaCompra.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                    <span style="background: @estadoColor; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 500; display: flex; align-items: center; gap: 4px;">
                        <md-icon style="font-size: 16px;">@estadoIcon</md-icon>
                        @compra.Estado
                    </span>
                </div>
            </div>

            <!-- Card Content -->
            <div style="padding: 24px;">
                <!-- Departamento -->
                @if (compra.Departamento != null)
                {
                    <div style="background: var(--md-sys-color-tertiary-container); border-radius: 8px; padding: 12px; display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
                        <md-icon style="color: var(--md-sys-color-on-tertiary-container); font-size: 20px;">business_center</md-icon>
                        <div>
                            <div class="md-typescale-label-small" style="color: var(--md-sys-color-on-tertiary-container);">Departamento Solicitante</div>
                            <div class="md-typescale-body-medium" style="font-weight: 500; color: var(--md-sys-color-on-tertiary-container);">@compra.Departamento.Nombre</div>
                        </div>
                    </div>
                }

                <!-- Proveedor -->
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                    <md-icon style="color: var(--md-sys-color-primary); font-size: 24px;">business</md-icon>
                    <div style="flex: 1;">
                        <div class="md-typescale-label-small" style="color: var(--md-sys-color-on-surface-variant); margin-bottom: 4px;">Proveedor</div>
                        <div class="md-typescale-title-medium" style="color: var(--md-sys-color-on-surface);">@compra.Proveedor</div>
                    </div>
                </div>

                <md-divider></md-divider>

                <!-- Details Grid -->
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 16px 0;">
                    <div>
                        <div class="md-typescale-label-small" style="color: var(--md-sys-color-on-surface-variant); margin-bottom: 4px;">Costo Total</div>
                        <div class="md-typescale-title-large" style="color: var(--md-sys-color-primary); font-weight: 600;">$@compra.CostoTotal.ToString("N2")</div>
                    </div>
                    <div>
                        <div class="md-typescale-label-small" style="color: var(--md-sys-color-on-surface-variant); margin-bottom: 4px;">Items Asociados</div>
                        <div style="display: flex; align-items: center; gap: 6px;">
                            <md-icon style="color: var(--md-sys-color-on-surface); font-size: 20px;">inventory_2</md-icon>
                            <span class="md-typescale-title-medium">@itemsCount</span>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(compra.NumeroFactura))
                {
                    <div style="background: var(--md-sys-color-surface-variant); border-radius: 8px; padding: 12px; display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
                        <md-icon style="color: var(--md-sys-color-on-surface-variant); font-size: 20px;">receipt</md-icon>
                        <div>
                            <div class="md-typescale-label-small" style="color: var(--md-sys-color-on-surface-variant);">Factura</div>
                            <div class="md-typescale-body-medium" style="font-weight: 500;">@compra.NumeroFactura</div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(compra.RutaFactura))
                {
                    <div style="background: var(--md-sys-color-primary-container); border-radius: 8px; padding: 12px; display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
                        @{
                            var extension = System.IO.Path.GetExtension(compra.RutaFactura).ToLower();
                            var isImage = extension == ".jpg" || extension == ".jpeg" || extension == ".png";
                            var fileName = System.IO.Path.GetFileName(compra.RutaFactura);
                        }
                        @if (isImage)
                        {
                            <md-icon style="color: var(--md-sys-color-on-primary-container); font-size: 20px;">image</md-icon>
                        }
                        else
                        {
                            <md-icon style="color: var(--md-sys-color-on-primary-container); font-size: 20px;">picture_as_pdf</md-icon>
                        }
                        <div style="flex: 1;">
                            <div class="md-typescale-label-small" style="color: var(--md-sys-color-on-primary-container); margin-bottom: 4px;">Factura adjunta</div>
                            <a href="@Url.Action("DescargarFactura", new { id = compra.Id })" 
                               style="color: var(--md-sys-color-on-primary-container); font-weight: 500; text-decoration: none; cursor: pointer; display: flex; align-items: center; gap: 4px;"
                               onclick="event.stopPropagation()"
                               onmouseover="this.style.textDecoration='underline'"
                               onmouseout="this.style.textDecoration='none'">
                                <span class="md-typescale-body-medium">@fileName</span>
                                <md-icon style="font-size: 18px;">download</md-icon>
                            </a>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(compra.Observaciones))
                {
                    <div style="background: var(--md-sys-color-secondary-container); border-radius: 8px; padding: 12px; margin-bottom: 16px;">
                        <div class="md-typescale-label-small" style="color: var(--md-sys-color-on-secondary-container); margin-bottom: 4px; display: flex; align-items: center; gap: 6px;">
                            <md-icon style="font-size: 16px;">note</md-icon>
                            Observaciones
                        </div>
                        <div class="md-typescale-body-small" style="color: var(--md-sys-color-on-secondary-container);">
                            @(compra.Observaciones.Length > 80 ? compra.Observaciones.Substring(0, 80) + "..." : compra.Observaciones)
                        </div>
                    </div>
                }

                <!-- Actions -->
                <div style="display: flex; gap: 8px; justify-content: flex-end;">
                    <md-filled-tonal-button onclick="event.stopPropagation(); window.location.href='@Url.Action("Details", new { id = compra.Id })'">
                        <md-icon slot="icon">visibility</md-icon>
                        Ver Detalle
                    </md-filled-tonal-button>
                    <md-icon-button onclick="event.stopPropagation(); window.location.href='@Url.Action("Edit", new { id = compra.Id })'">
                        <md-icon>edit</md-icon>
                    </md-icon-button>
                    <md-icon-button onclick="event.stopPropagation(); confirmDelete(@compra.Id, '@compra.FechaCompra.ToString("dd/MM/yyyy")')">
                        <md-icon>delete</md-icon>
                    </md-icon-button>
                </div>
            </div>
        </div>
    }
</div>

@if (totalPages > 1)
{
    <div style="display:flex; gap:12px; justify-content:flex-end; align-items:center; margin-top:20px;">
        <span class="md-typescale-body-small">Página @currentPage de @totalPages</span>
        <md-outlined-button onclick="window.location.href='@Url.Action("Index", new { q, page = currentPage - 1, pageSize })'" @(currentPage <= 1 ? "disabled" : "")>Anterior</md-outlined-button>
        <md-outlined-button onclick="window.location.href='@Url.Action("Index", new { q, page = currentPage + 1, pageSize })'" @(currentPage >= totalPages ? "disabled" : "")>Siguiente</md-outlined-button>
    </div>
}

@if (!compras.Any())
{
    <div class="empty-state" style="padding: 80px 20px; text-align: center;">
        <md-icon style="font-size: 96px; color: var(--md-sys-color-outline); opacity: 0.5;">shopping_cart</md-icon>
        <h3 class="md-typescale-headline-medium" style="margin: 24px 0 12px;">No hay compras registradas</h3>
        <p class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface-variant); margin-bottom: 32px;">
            Comienza registrando tu primera compra de inventario
        </p>
        <md-filled-button onclick="window.location.href='@Url.Action("Create")'">
            <md-icon slot="icon">add</md-icon>
            Crear Primera Compra
        </md-filled-button>
    </div>
}

@section Scripts {
    <script>
        async function confirmDelete(id, fecha) {
            if (await showConfirmDialog(
                'Eliminar Compra',
                `¿Estás seguro de eliminar la compra del ${fecha}?`,
                'Eliminar'
            )) {
                const formData = new FormData();
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
                
                const response = await fetch(`@Url.Action("Delete")/` + id, {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showSnackbar(result.message, 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showSnackbar(result.message, 'error');
                }
            }
        }
    </script>
    @Html.AntiForgeryToken()
}
