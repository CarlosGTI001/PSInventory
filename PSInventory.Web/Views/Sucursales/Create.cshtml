@model PSData.Modelos.Sucursal

@{
    ViewData["Title"] = "Nueva Sucursal";
}

<!-- Breadcrumb -->
<div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; color: var(--md-sys-color-on-surface-variant); font-size: 14px;">
    <md-icon style="font-size: 18px;">home</md-icon>
    <span>Administración</span>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <a href="@Url.Action("Index")" style="color: var(--md-sys-color-on-surface-variant); text-decoration: none;">Sucursales</a>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <span style="color: var(--md-sys-color-primary);">Nueva</span>
</div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="md-typescale-display-small" style="margin: 0 0 8px 0;">Registrar Nueva Sucursal</h1>
        <p class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface-variant); margin: 0;">
            Ingresa los datos de la nueva sucursal
        </p>
    </div>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    
    <!-- Sección 1: Información General -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid var(--md-sys-color-primary);">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(4, 115, 148, 0.15); display: flex; align-items: center; justify-content: center;">
                <md-icon style="color: var(--md-sys-color-primary); font-size: 28px;">store</md-icon>
            </div>
            <div>
                <h2 class="md-typescale-title-large" style="margin: 0;">Información General</h2>
                <p class="md-typescale-body-small" style="margin: 4px 0 0; color: var(--md-sys-color-on-surface-variant);">Datos básicos de la sucursal</p>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <md-filled-text-field 
                    label="Nombre *" 
                    name="Nombre" 
                    required
                    value="@Model?.Nombre"
                    supporting-text="Nombre de la sucursal">
                    <md-icon slot="leading-icon">label</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="Nombre" class="field-error"></span>
            </div>
            
            <div class="form-field">
                <div class="md3-select-field has-leading-icon">
                    <md-icon class="md3-select-leading-icon">location_on</md-icon>
                    <select asp-for="RegionId" class="md3-select" required>
                        <option value="">Seleccione una región</option>
                        @foreach (var region in ViewBag.Regiones)
                        {
                            <option value="@region.Value">@region.Text</option>
                        }
                    </select>
                    <label class="md3-select-label">Región *</label>
                </div>
                <p class="md3-select-supporting">Región donde está ubicada</p>
                <span asp-validation-for="RegionId" class="field-error"></span>
            </div>
        </div>
    </div>

    <!-- Sección 2: Ubicación y Contacto -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid var(--md-sys-color-secondary);">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(255, 92, 0, 0.15); display: flex; align-items: center; justify-content: center;">
                <md-icon style="color: var(--md-sys-color-secondary); font-size: 28px;">place</md-icon>
            </div>
            <div>
                <h2 class="md-typescale-title-large" style="margin: 0;">Ubicación y Contacto</h2>
                <p class="md-typescale-body-small" style="margin: 4px 0 0; color: var(--md-sys-color-on-surface-variant);">Dirección y teléfono</p>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <md-filled-text-field 
                    label="Dirección" 
                    name="Direccion" 
                    value="@Model?.Direccion"
                    supporting-text="Dirección completa">
                    <md-icon slot="leading-icon">place</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="Direccion" class="field-error"></span>
            </div>
            
            <div class="form-field">
                <md-filled-text-field 
                    label="Teléfono" 
                    name="Telefono" 
                    type="tel"
                    value="@Model?.Telefono"
                    supporting-text="Teléfono de contacto">
                    <md-icon slot="leading-icon">phone</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="Telefono" class="field-error"></span>
            </div>
        </div>
    </div>

    <!-- Form Actions -->
    <div class="form-actions" style="background: var(--md-sys-color-surface-container); padding: 24px; border-radius: 16px; box-shadow: var(--md-sys-elevation-level2);">
        <md-text-button onclick="window.location.href='@Url.Action("Index")'; return false;">
            <md-icon slot="icon">cancel</md-icon>
            Cancelar
        </md-text-button>
        <md-filled-button type="submit" style="height: 48px; min-width: 160px;">
            <md-icon slot="icon">save</md-icon>
            Guardar Sucursal
        </md-filled-button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
