@model PSData.Modelos.Compra

@{
    ViewData["Title"] = "Editar Compra";
}

<!-- Breadcrumb -->
<div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; color: var(--md-sys-color-on-surface-variant); font-size: 14px;">
    <md-icon style="font-size: 18px;">home</md-icon>
    <span>Inventario</span>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <a href="@Url.Action("Index")" style="color: var(--md-sys-color-on-surface-variant); text-decoration: none;">Compras</a>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <span style="color: var(--md-sys-color-primary);">Editar: @Model.Proveedor</span>
</div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="md-typescale-display-small" style="margin: 0 0 8px 0;">Editar Compra</h1>
        <p class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface-variant); margin: 0;">
            Modifica los datos de la compra de <strong>@Model.Proveedor</strong>
        </p>
    </div>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    
    <!-- Sección 1: Información General -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid var(--md-sys-color-primary);">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(4, 115, 148, 0.15); display: flex; align-items: center; justify-content: center;">
                <md-icon style="color: var(--md-sys-color-primary); font-size: 28px;">receipt_long</md-icon>
            </div>
            <div>
                <h2 class="md-typescale-title-large" style="margin: 0;">Información General</h2>
                <p class="md-typescale-body-small" style="margin: 4px 0 0; color: var(--md-sys-color-on-surface-variant);">Datos básicos de la compra</p>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <md-filled-text-field 
                    label="Fecha de Compra *" 
                    name="FechaCompra" 
                    type="date"
                    required
                    value="@Model.FechaCompra.ToString("yyyy-MM-dd")"
                    supporting-text="Fecha de la compra">
                    <md-icon slot="leading-icon">event</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="FechaCompra" class="field-error"></span>
            </div>
            
            <div class="form-field">
                <md-filled-text-field 
                    label="Proveedor *" 
                    name="Proveedor" 
                    required
                    value="@Model.Proveedor"
                    supporting-text="Nombre o razón social">
                    <md-icon slot="leading-icon">business</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="Proveedor" class="field-error"></span>
            </div>
        </div>
        
        <div class="form-row">
            <div class="form-field">
                <md-filled-text-field 
                    label="Costo Total *" 
                    name="CostoTotal" 
                    type="number"
                    step="0.01"
                    required
                    value="@Model.CostoTotal"
                    supporting-text="Monto total en pesos">
                    <md-icon slot="leading-icon">attach_money</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="CostoTotal" class="field-error"></span>
            </div>

            <div class="form-field">
                <div class="md3-select-field has-leading-icon">
                    <md-icon class="md3-select-leading-icon">check_circle</md-icon>
                    <select asp-for="Estado" name="Estado" class="md3-select" required>
                        <option value="Pendiente" selected="@(Model.Estado == "Pendiente")">Pendiente</option>
                        <option value="Completada" selected="@(Model.Estado == "Completada")">Completada</option>
                        <option value="Cancelada" selected="@(Model.Estado == "Cancelada")">Cancelada</option>
                    </select>
                    <label class="md3-select-label">Estado *</label>
                </div>
                <p class="md3-select-supporting">Estado actual de la compra</p>
                <span asp-validation-for="Estado" class="field-error"></span>
            </div>
        </div>
    </div>

    <!-- Sección 2: Documentación -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid var(--md-sys-color-secondary);">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(255, 92, 0, 0.15); display: flex; align-items: center; justify-content: center;">
                <md-icon style="color: var(--md-sys-color-secondary); font-size: 28px;">receipt</md-icon>
            </div>
            <div>
                <h2 class="md-typescale-title-large" style="margin: 0;">Documentación</h2>
                <p class="md-typescale-body-small" style="margin: 4px 0 0; color: var(--md-sys-color-on-surface-variant);">Información de facturación (opcional)</p>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <md-filled-text-field 
                    label="Número de Factura" 
                    name="NumeroFactura" 
                    value="@Model?.NumeroFactura"
                    supporting-text="Número de factura del proveedor">
                    <md-icon slot="leading-icon">tag</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="NumeroFactura" class="field-error"></span>
            </div>
        </div>

        <!-- Campo para adjuntar factura -->
        @if (!string.IsNullOrEmpty(Model?.RutaFactura))
        {
            <div class="form-row" style="margin-top: 16px;">
                <div class="form-field" style="width: 100%;">
                    <div style="display: flex; align-items: center; gap: 12px; padding: 16px; background: var(--md-sys-color-surface-container-high); border-radius: 12px; border: 2px solid var(--md-sys-color-primary); margin-bottom: 16px;">
                        <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(4, 115, 148, 0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            @{
                                var extension = System.IO.Path.GetExtension(Model.RutaFactura).ToLower();
                                var isImage = extension == ".jpg" || extension == ".jpeg" || extension == ".png";
                                var fileName = System.IO.Path.GetFileName(Model.RutaFactura);
                            }
                            @if (isImage)
                            {
                                <md-icon style="color: var(--md-sys-color-primary); font-size: 28px;">image</md-icon>
                            }
                            else
                            {
                                <md-icon style="color: var(--md-sys-color-primary); font-size: 28px;">picture_as_pdf</md-icon>
                            }
                        </div>
                        <div style="flex: 1;">
                            <div class="md-typescale-body-medium" style="color: var(--md-sys-color-on-surface); margin-bottom: 4px;">
                                <strong>Factura actual:</strong> @fileName
                            </div>
                        </div>
                        <a href="@Url.Action("DescargarFactura", new { id = Model.Id })" 
                           style="padding: 8px 16px; background: var(--md-sys-color-primary); color: white; border-radius: 8px; text-decoration: none; display: flex; align-items: center; gap: 8px; cursor: pointer; transition: all 0.2s ease;"
                           onmouseover="this.style.background='var(--md-sys-color-on-primary-container)'"
                           onmouseout="this.style.background='var(--md-sys-color-primary)'">
                            <md-icon style="font-size: 20px;">download</md-icon>
                            <span class="md-typescale-label-large">Descargar</span>
                        </a>
                    </div>
                </div>
            </div>
        }

        <div class="form-row" style="margin-top: 16px;">
            <div class="form-field" style="width: 100%;">
                <label style="display: flex; align-items: center; gap: 12px; padding: 20px; background: var(--md-sys-color-surface-container-high); border-radius: 12px; border: 2px dashed var(--md-sys-color-outline); cursor: pointer; transition: all 0.3s ease;">
                    <input type="file" 
                           name="facturaFile" 
                           id="facturaFile" 
                           accept=".pdf,.jpg,.jpeg,.png"
                           style="display: none;"
                           onchange="updateFileLabel(this)">
                    <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(255, 92, 0, 0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <md-icon style="color: var(--md-sys-color-secondary); font-size: 28px;">attach_file</md-icon>
                    </div>
                    <div style="flex: 1;">
                        <div id="fileLabel" class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface); margin-bottom: 4px;">
                            @(string.IsNullOrEmpty(Model?.RutaFactura) ? "Adjuntar factura escaneada" : "Cambiar factura")
                        </div>
                        <div class="md-typescale-body-small" style="color: var(--md-sys-color-on-surface-variant);">
                            PDF, JPG, JPEG o PNG (Opcional)
                        </div>
                    </div>
                    <md-icon style="color: var(--md-sys-color-on-surface-variant);">cloud_upload</md-icon>
                </label>
            </div>
        </div>
    </div>

    <!-- Sección 3: Observaciones -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid var(--md-sys-color-tertiary);">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(91, 201, 229, 0.15); display: flex; align-items: center; justify-content: center;">
                <md-icon style="color: var(--md-sys-color-tertiary); font-size: 28px;">description</md-icon>
            </div>
            <div>
                <h2 class="md-typescale-title-large" style="margin: 0;">Observaciones</h2>
                <p class="md-typescale-body-small" style="margin: 4px 0 0; color: var(--md-sys-color-on-surface-variant);">Notas adicionales (opcional)</p>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <md-filled-text-field 
                    label="Observaciones" 
                    name="Observaciones" 
                    type="textarea"
                    rows="4"
                    value="@Model.Observaciones"
                    supporting-text="Información relevante sobre la compra">
                    <md-icon slot="leading-icon">note_alt</md-icon>
                </md-filled-text-field>
                <span asp-validation-for="Observaciones" class="field-error"></span>
            </div>
        </div>
    </div>

    <!-- Form Actions -->
    <div class="form-actions" style="background: var(--md-sys-color-surface-container); padding: 24px; border-radius: 16px; box-shadow: var(--md-sys-elevation-level2);">
        <md-text-button onclick="window.location.href='@Url.Action("Index")'; return false;">
            <md-icon slot="icon">cancel</md-icon>
            Cancelar
        </md-text-button>
        <md-filled-button type="submit" style="height: 48px; min-width: 160px;">
            <md-icon slot="icon">save</md-icon>
            Guardar Cambios
        </md-filled-button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        function updateFileLabel(input) {
            const label = document.getElementById('fileLabel');
            if (input.files && input.files[0]) {
                const file = input.files[0];
                const fileName = file.name;
                const fileSize = (file.size / 1024).toFixed(2); // KB
                label.innerHTML = `<md-icon style="font-size: 20px; color: var(--md-sys-color-primary);">check_circle</md-icon> ${fileName} (${fileSize} KB)`;
                
                // Cambiar estilo del contenedor
                input.closest('label').style.borderColor = 'var(--md-sys-color-primary)';
                input.closest('label').style.background = 'rgba(4, 115, 148, 0.08)';
            } else {
                label.textContent = @(string.IsNullOrEmpty(Model?.RutaFactura) ? "'Adjuntar factura escaneada'" : "'Cambiar factura'");
                input.closest('label').style.borderColor = 'var(--md-sys-color-outline)';
                input.closest('label').style.background = 'var(--md-sys-color-surface-container-high)';
            }
        }
        
        // Click en el label activa el input
        document.querySelector('label[for="facturaFile"]')?.addEventListener('click', function(e) {
            if (e.target.tagName !== 'INPUT') {
                document.getElementById('facturaFile').click();
            }
        });
    </script>
}
