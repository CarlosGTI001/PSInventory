@model IEnumerable<PSData.Modelos.Sucursal>

@{
    ViewData["Title"] = "Sucursales";
    var totalSucursales = ViewBag.TotalCount != null ? (int)ViewBag.TotalCount : Model.Count();
    var conTelefono = Model.Count(s => !string.IsNullOrEmpty(s.Telefono));
    var regiones = Model.Select(s => s.Region?.Nombre).Distinct().Count();
    var q = ViewBag.Query as string ?? "";
    var currentPage = ViewBag.Page != null ? (int)ViewBag.Page : 1;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var pageSize = ViewBag.PageSize != null ? (int)ViewBag.PageSize : 30;
}

<!-- Breadcrumb -->
<div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; color: var(--md-sys-color-on-surface-variant); font-size: 14px;">
    <md-icon style="font-size: 18px;">home</md-icon>
    <span>Configuración</span>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <span style="color: var(--md-sys-color-primary);">Sucursales</span>
</div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="md-typescale-display-small" style="margin: 0 0 8px 0;">Sucursales de la Empresa</h1>
        <p class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface-variant); margin: 0;">
            Administra las ubicaciones y puntos de operación
        </p>
    </div>
    <md-filled-button onclick="window.location.href='@Url.Action("Create")'">
        <md-icon slot="icon">add</md-icon>
        Nueva Sucursal
    </md-filled-button>
</div>

<!-- Stats Cards -->
<div class="stats-grid" style="margin-bottom: 32px;">
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value">@totalSucursales</div>
                <div class="stat-card-label">Total Sucursales</div>
            </div>
            <div class="stat-card-icon">
                <md-icon>store</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-success);">@conTelefono</div>
                <div class="stat-card-label">Con Teléfono</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(76, 175, 80, 0.15);">
                <md-icon style="color: var(--md-sys-color-success);">phone</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-secondary);">@regiones</div>
                <div class="stat-card-label">Regiones</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(255, 92, 0, 0.15);">
                <md-icon style="color: var(--md-sys-color-secondary);">location_city</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-primary);">@totalSucursales</div>
                <div class="stat-card-label">Activas</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(4, 115, 148, 0.15);">
                <md-icon style="color: var(--md-sys-color-primary);">check_circle</md-icon>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <md-icon>check_circle</md-icon>
        <span>@TempData["Success"]</span>
    </div>
}

<!-- Data Table -->
<div class="card">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <md-icon style="color: var(--md-sys-color-primary);">table_chart</md-icon>
            <h3 class="md-typescale-title-medium" style="margin: 0;">Lista de Sucursales</h3>
        </div>
        <span class="md-typescale-body-medium" style="color: var(--md-sys-color-on-surface-variant);">
            @totalSucursales sucursal@(totalSucursales != 1 ? "es" : "") registrada@(totalSucursales != 1 ? "s" : "")
        </span>
    </div>
    <form method="get" action="@Url.Action("Index")" style="display:flex; gap:12px; align-items:end; margin-bottom:16px; flex-wrap:wrap;">
        <md-filled-text-field name="q" label="Buscar sucursal" value="@q" style="min-width:280px;">
            <md-icon slot="leading-icon">search</md-icon>
        </md-filled-text-field>
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="@pageSize" />
        <md-filled-button type="submit"><md-icon slot="icon">search</md-icon>Filtrar</md-filled-button>
        <md-text-button onclick="window.location.href='@Url.Action("Index")'; return false;">Limpiar</md-text-button>
    </form>

    <div class="data-table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Región</th>
                    <th>Dirección</th>
                    <th>Teléfono</th>
                    <th class="actions-column">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <md-icon style="color: var(--md-sys-color-primary); font-size: 20px;">storefront</md-icon>
                                <strong>@item.Nombre</strong>
                            </div>
                        </td>
                        <td>
                            <span class="badge badge-secondary">@item.Region?.Nombre</span>
                        </td>
                        <td>@item.Direccion</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Telefono))
                            {
                                <div style="display: flex; align-items: center; gap: 4px;">
                                    <md-icon style="font-size: 16px; color: var(--md-sys-color-on-surface-variant);">phone</md-icon>
                                    <span>@item.Telefono</span>
                                </div>
                            }
                            else
                            {
                                <span style="color: var(--md-sys-color-outline);">—</span>
                            }
                        </td>
                        <td class="actions-cell">
                            <md-icon-button onclick="window.location.href='@Url.Action("Edit", new { id = item.Id })'">
                                <md-icon>edit</md-icon>
                            </md-icon-button>
                            <md-icon-button onclick="confirmDelete(@item.Id, '@item.Nombre')">
                                <md-icon>delete</md-icon>
                            </md-icon-button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (totalPages > 1)
    {
        <div style="display:flex; gap:12px; justify-content:flex-end; align-items:center; margin-top:16px;">
            <span class="md-typescale-body-small">Página @currentPage de @totalPages</span>
            <md-outlined-button onclick="window.location.href='@Url.Action("Index", new { q, page = currentPage - 1, pageSize })'" @(currentPage <= 1 ? "disabled" : "")>Anterior</md-outlined-button>
            <md-outlined-button onclick="window.location.href='@Url.Action("Index", new { q, page = currentPage + 1, pageSize })'" @(currentPage >= totalPages ? "disabled" : "")>Siguiente</md-outlined-button>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <md-icon style="font-size: 64px; color: var(--md-sys-color-outline);">store</md-icon>
        <h3 class="md-typescale-headline-small">No hay sucursales registradas</h3>
        <p class="md-typescale-body-medium">Comienza creando tu primera sucursal</p>
        <md-filled-button onclick="window.location.href='@Url.Action("Create")'">
            <md-icon slot="icon">add</md-icon>
            Crear Sucursal
        </md-filled-button>
    </div>
}

@section Scripts {
    <script>
        async function confirmDelete(id, nombre) {
            if (await showConfirmDialog(
                'Eliminar Sucursal',
                `¿Estás seguro de eliminar la sucursal "${nombre}"?`,
                'Eliminar'
            )) {
                const formData = new FormData();
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
                
                const response = await fetch(`@Url.Action("Delete")/` + id, {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showSnackbar(result.message, 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showSnackbar(result.message, 'error');
                }
            }
        }
    </script>
    @Html.AntiForgeryToken()
}
