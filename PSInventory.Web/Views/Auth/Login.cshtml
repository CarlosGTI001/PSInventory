@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PSInventory</title>
    
    <!-- Material Design 3 -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <!-- Material Symbols (iconos MD3 modernos) -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <!-- Material Icons (compatibilidad) -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    
    <link rel="stylesheet" href="~/css/material-theme.css" />
    
    <!-- Material Web Components -->
    <script type="importmap">
    {
        "imports": {
            "@@material/web/": "https://esm.run/@@material/web/"
        }
    }
    </script>
    <script type="module">
        import '@@material/web/all.js';
    </script>
    
    <style>
        body {
            margin: 0;
            font-family: 'Roboto', sans-serif;
            background: linear-gradient(135deg, #047394 0%, #035a72 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        
        .login-container {
            background: var(--md-sys-color-surface-container);
            border-radius: 24px;
            padding: 48px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
            border: 1px solid var(--md-sys-color-outline-variant);
        }
        
        .login-header {
            text-align: center;
            margin-bottom: 32px;
        }
        
        .login-logo {
            width: 160px;
            height: auto;
            margin: 0 auto 24px;
            display: block;
            border-radius: 16px;
            border: 3px solid var(--md-sys-color-primary);
            box-shadow: 0 4px 12px rgba(4, 115, 148, 0.4);
        }
        
        .login-title {
            font-size: 28px;
            font-weight: 500;
            color: var(--md-sys-color-on-surface);
            margin-bottom: 8px;
        }
        
        .login-subtitle {
            color: var(--md-sys-color-on-surface-variant);
            font-size: 14px;
        }
        
        .login-form {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        
        .form-field {
            width: 100%;
        }
        
        .error-message {
            background: rgba(255, 84, 73, 0.15);
            color: var(--md-sys-color-error);
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 14px;
            border: 1px solid rgba(255, 84, 73, 0.3);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .login-actions {
            margin-top: 8px;
        }
        
        .login-actions md-filled-button {
            width: 100%;
            height: 48px;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <img src="~/images/logo.png" alt="Presidente Sports" class="login-logo" />
            <h1 class="login-title">PSInventory</h1>
            <p class="login-subtitle">Sistema de Gestión de Inventario</p>
        </div>
        
        <form method="post" class="login-form">
            @if (ViewBag.Error != null)
            {
                <div class="error-message">
                    <md-icon>error</md-icon>
                    <span>@ViewBag.Error</span>
                </div>
            }
            
            <md-filled-text-field 
                label="Usuario" 
                name="username" 
                required
                type="text"
                class="form-field">
                <md-icon slot="leading-icon">person</md-icon>
            </md-filled-text-field>
            
            <md-filled-text-field 
                label="Contraseña" 
                name="password" 
                required
                type="password"
                class="form-field">
                <md-icon slot="leading-icon">lock</md-icon>
            </md-filled-text-field>
            
            <div class="login-actions">
                <md-filled-button type="submit">
                    Iniciar Sesión
                    <md-icon slot="icon">login</md-icon>
                </md-filled-button>
            </div>
        </form>
    </div>
</body>
</html>
