@model IEnumerable<PSData.Modelos.Usuario>

@{
    ViewData["Title"] = "Usuarios";
    var totalUsuarios = Model.Count();
    var administradores = Model.Count(u => u.Rol == "Administrador");
    var operadores = Model.Count(u => u.Rol != "Administrador");
}

<!-- Breadcrumb -->
<div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px; color: var(--md-sys-color-on-surface-variant); font-size: 14px;">
    <md-icon style="font-size: 18px;">home</md-icon>
    <span>Configuración</span>
    <md-icon style="font-size: 18px;">chevron_right</md-icon>
    <span style="color: var(--md-sys-color-primary);">Usuarios</span>
</div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="md-typescale-display-small" style="margin: 0 0 8px 0;">Usuarios del Sistema</h1>
        <p class="md-typescale-body-large" style="color: var(--md-sys-color-on-surface-variant); margin: 0;">
            Gestiona los usuarios y sus permisos de acceso
        </p>
    </div>
    <md-filled-button onclick="window.location.href='@Url.Action("Create")'">
        <md-icon slot="icon">add</md-icon>
        Nuevo Usuario
    </md-filled-button>
</div>

<!-- Stats Cards -->
<div class="stats-grid" style="margin-bottom: 32px;">
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value">@totalUsuarios</div>
                <div class="stat-card-label">Total Usuarios</div>
            </div>
            <div class="stat-card-icon">
                <md-icon>group</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-error);">@administradores</div>
                <div class="stat-card-label">Administradores</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(244, 67, 54, 0.15);">
                <md-icon style="color: var(--md-sys-color-error);">admin_panel_settings</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-secondary);">@operadores</div>
                <div class="stat-card-label">Operadores</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(255, 92, 0, 0.15);">
                <md-icon style="color: var(--md-sys-color-secondary);">badge</md-icon>
            </div>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-card-header">
            <div>
                <div class="stat-card-value" style="color: var(--md-sys-color-success);">@Model.Count(u => !string.IsNullOrEmpty(u.Email))</div>
                <div class="stat-card-label">Con Email</div>
            </div>
            <div class="stat-card-icon" style="background: rgba(76, 175, 80, 0.15);">
                <md-icon style="color: var(--md-sys-color-success);">email</md-icon>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <md-icon>check_circle</md-icon>
        <span>@TempData["Success"]</span>
    </div>
}

<!-- Data Table -->
<div class="card">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <md-icon style="color: var(--md-sys-color-primary);">table_chart</md-icon>
            <h3 class="md-typescale-title-medium" style="margin: 0;">Lista de Usuarios</h3>
        </div>
        <span class="md-typescale-body-medium" style="color: var(--md-sys-color-on-surface-variant);">
            @totalUsuarios usuario@(totalUsuarios != 1 ? "s" : "") registrado@(totalUsuarios != 1 ? "s" : "")
        </span>
    </div>

    <div class="data-table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th class="actions-column">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var rolClass = item.Rol == "Administrador" ? "badge-error" : "badge-primary";
                    
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <md-icon style="color: var(--md-sys-color-on-surface-variant); font-size: 20px;">account_circle</md-icon>
                                <strong>@item.Nombre</strong>
                            </div>
                        </td>
                        <td>@item.Email</td>
                        <td>
                            <span class="@rolClass">@item.Rol</span>
                        </td>
                        <td class="actions-cell">
                            <md-icon-button onclick="window.location.href='@Url.Action("Edit", new { id = item.Id })'">
                                <md-icon>edit</md-icon>
                            </md-icon-button>
                            <md-icon-button onclick="confirmDelete('@item.Id', '@item.Nombre')">
                                <md-icon>delete</md-icon>
                            </md-icon-button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        async function confirmDelete(id, nombre) {
            if (await showConfirmDialog(
                'Eliminar Usuario',
                `¿Estás seguro de eliminar el usuario "${nombre}"?`,
                'Eliminar'
            )) {
                const formData = new FormData();
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
                
                const response = await fetch(`@Url.Action("Delete")/` + id, {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showSnackbar(result.message, 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showSnackbar(result.message, 'error');
                }
            }
        }
    </script>
    @Html.AntiForgeryToken()
}
